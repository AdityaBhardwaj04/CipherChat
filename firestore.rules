rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      // Anyone can read public keys — RSA public keys are public by design
      allow read: if true;
      // Only the owning user can write their own profile
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /usernames/{username} {
      // Anyone can read the username→uid index — needed by CLI and browser for key lookup
      allow read: if true;
      // Only the authenticated user can claim their own username.
      // Server-side: enforce ownership and format (3-20 chars, lowercase alphanumeric + underscore).
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && username.size() >= 3
                    && username.size() <= 20
                    && username.matches('^[a-z0-9_]+$');
      // Usernames are immutable — no updates or deletes
      allow update, delete: if false;
    }

    match /messages/{messageId} {
      // Authenticated users can read and write messages.
      // Content security is provided by end-to-end encryption — the server
      // never has access to plaintext regardless of these rules.
      allow read, write: if request.auth != null;
    }
  }
}
